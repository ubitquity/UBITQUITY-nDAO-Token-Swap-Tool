# UBITQUITY + nDAO Token Swap Tool — Environment Configuration
# Copy to .env and customize for your deployment.
# NEVER commit .env to version control.

# Application mode: production | development
APP_ENV=production

# Comma-separated list of allowed CORS origins (leave empty for same-origin only)
ALLOWED_ORIGINS=

# Salt for IP address hashing (change this to a random value in production)
IP_HASH_SALT=change-me-to-random-string

# Admin API key for audit log access (leave empty to allow unauthenticated reads)
ADMIN_API_KEY=
